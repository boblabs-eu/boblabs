# Bob Manager
# Distributed GPU Server Management Platform

BOB_MANAGER_VERSION=1.0.0

# ── Control Plane ──────────────────────────────
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8000

# ── Database ───────────────────────────────────
POSTGRES_USER=bobmanager
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=bobmanager
POSTGRES_HOST=bob-db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Security ───────────────────────────────────
AGENT_SECRET=change-this-to-a-random-secret-token
JWT_SECRET=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Frontend ───────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
REACT_APP_CONTACT_EMAIL=support@boblabs.eu

# ── Hugging Face API Token ─────────────────────
HF_TOKEN=hf_your_token_here

# ── Admin ──────────────────────────────────────
ADMIN_SECRET=very_strong_and_random_secret_key_here
ADMIN_EMAIL=support@yourdomain.com
SMTP_HOST=hosting_provider_smtp_server.com
SMTP_PORT=587
SMTP_USER=support@yourdomain.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=support@yourdomain.com
APP_BASE_URL=https://yourdomain.com

# ── Network Binding ────────────────────────────
# Default 0.0.0.0 (all interfaces) for dev
# Set to 127.0.0.1 for production (localhost only, behind nginx)
#BIND_ADDR=127.0.0.1

# ── Environment Variables for Agents ──────────────────────────────────────
# ── YouTube ──────────────────────────────────────
YOUTUBE_DATA_V3_API_KEY=xx-xxx

# ── Twitter ──────────────────────────────────────
AGENT_X_CONSURMER_KEY=xxx # API Key for Twitter API v1.1
AGENT_X_CONSUMER_SECRET=xxx # API Secret Key for Twitter API v1.1
AGENT_X_ACCESS_TOKEN=xxx-xxx # Access Token for Twitter API v1.1
AGENT_X_ACCESS_TOKEN_SECRET=xxx # Access Token Secret for Twitter API v1.1
AGENT_X_TWITTER_BEARER_TOKEN=xx%xx%xx # Bearer Token for Twitter API v2

# ── Email (SMTP/IMAP) ──────────────────────────────────────
AGENT_SMTP_HOST=smtp.gmail.com
AGENT_SMTP_PORT=587
AGENT_SMTP_USER=test@gmail.com
AGENT_SMTP_PASSWORD=xx
AGENT_SMTP_FROM=test@gmail.com
AGENT_IMAP_HOST=smtp.gmail.com
AGENT_IMAP_PORT=993
AGENT_IMAP_USER=test@gmail.com
AGENT_IMAP_PASSWORD=ss
AGENT_SMTP_USE_TLS=true
AGENT_IMAP_USE_TLS=true

# ── Web3 ──────────────────────────────────────
TRADING_PRIVATE_KEYS=["0x123","0x456"]
ONEINCH_API_KEY=your_1inch_api_key_here


# ── Consumer apps ───────────────────────────────────────
#
# Consumer apps (private overlays that drive bob-api) authenticate via the
# ``consumer_apps`` Postgres table — managed in bob-ui → Admin → Consumer
# Apps. No env vars needed here; per-app HMAC keys live entirely in the DB.