# Copy this file to .env  ->  cp .env.example .env   (and keep .env out of git)

# ---------------------------------------------------------------------------
# Subscription auth (Max plan). Generate ONCE on a machine with a browser:
#
#   claude setup-token
#
# Copy the printed token here. It starts with sk-ant-oat01- and bills against
# your Max subscription, not pay-as-you-go API credits.
# ---------------------------------------------------------------------------
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Models offered to the fleet (THE source of truth — nothing is hardcoded).
# Bare aliases track the latest model of each tier. Pin an exact id
# (e.g. claude-opus-4-8) if you want a fixed version.
CLAUDE_CLI_MODELS=haiku,opus,sonnet

# Host port the wrapper listens on (the agent reports this to the
# control plane; keep in sync with CLAUDE_CLI_URL in /etc/bob-agent.env).
CLAUDE_CLI_PORT=3021

# Max concurrent `claude -p` one-shots (each is its own subprocess).
CLAUDE_CLI_CONCURRENCY=2

# Per-request timeout. Keep under the control plane's 600s read timeout.
CLAUDE_CLI_TIMEOUT_SEC=300

# Native Claude Code tools available to each one-shot. The lab drives tools
# itself (the model only emits <tool_call> TEXT blocks the control plane runs),
# so the model must have NO native tools — otherwise it emits a real tool_use,
# spends its single turn on it, and aborts with `error_max_turns`.
#   ""        -> disable ALL tools (correct for lab use; the default)
#   "Read,Bash" -> allow only those (rare; only if you really want native tools)
CLAUDE_CLI_TOOLS=

# --- Full-capacity agent models (claude-agent:*) ---------------------------
# OPT-IN. Each id listed here is ALSO served as claude-agent:<id>, which runs
# Claude Code as a REAL agent: its OWN tools (Bash/Read/Write/WebSearch/Task/…),
# multi-turn, non-interactive permissions — NOT the text-only model above. The
# control plane routes a claude-agent:* agent straight here and takes the final
# result text. Empty = feature OFF.  Example:  CLAUDE_CLI_AGENT_MODELS=opus
CLAUDE_CLI_AGENT_MODELS=
# Max agentic turns per request (multi-turn tool loop).
CLAUDE_CLI_AGENT_MAX_TURNS=40
# Longer than the text timeout — agentic runs do multiple turns + tool calls.
CLAUDE_CLI_AGENT_TIMEOUT_SEC=900
# Permission handling for headless tool execution. Empty => --dangerously-skip-
# permissions (container is the sandbox; runs as non-root 'claude', so allowed).
# Set acceptEdits|plan|… to use --permission-mode instead.
CLAUDE_CLI_AGENT_PERMISSION_MODE=
# Extra args appended to the agentic `claude -p` invocation (advanced).
CLAUDE_CLI_AGENT_EXTRA_ARGS=

# Optional: require "Authorization: Bearer <key>" on /v1/* endpoints.
# Put the same value in the provider's api_key field in the control plane.
# Empty = unauthenticated (Ollama-style LAN trust; firewall port 3021).
CLAUDE_CLI_API_KEY=
